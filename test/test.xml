<?xml version="1.0" encoding="UTF-8"?>
<definitions
    xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    id="definitions"
    name="Simple Process Definition"
    targetNamespace="http://example.com/bpmn">

  <process id="simpleProcess" name="Simple Process" isExecutable="true">

    <startEvent id="startEvent" name="Start Event">
      <outgoing>sequenceFlow1</outgoing>
    </startEvent>

    <sequenceFlow
        id="sequenceFlow1"
        name="Sequence Flow 1"
        sourceRef="startEvent"
        targetRef="task" />

    <task id="task" name="Task">
      <incoming>sequenceFlow1</incoming>
      <outgoing>sequenceFlow2</outgoing>
    </task>

    <sequenceFlow
        id="sequenceFlow2"
        name="Sequence Flow 2"
        sourceRef="task"
        targetRef="endEvent" />

    <endEvent id="endEvent" name="End Event">
      <incoming>sequenceFlow2</incoming>
    </endEvent>

  </process>

  <bpmndi:BPMNDiagram id="bpmnDiagram">
    <bpmndi:BPMNPlane
        id="bpmnPlane"
        bpmnElement="simpleProcess">

      <bpmndi:BPMNShape
          id="startEventShape"
          bpmnElement="startEvent">
        <dc:Bounds x="180" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape
          id="taskShape"
          bpmnElement="task">
        <dc:Bounds x="330" y="138" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape
          id="endEventShape"
          bpmnElement="endEvent">
        <dc:Bounds x="480" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge
          id="sequenceFlow1Edge"
          bpmnElement="sequenceFlow1">
        <di:waypoint x="216" y="178"/>
        <di:waypoint x="330" y="178"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge
          id="sequenceFlow2Edge"
          bpmnElement="sequenceFlow2">
        <di:waypoint x="430" y="178"/>
        <di:waypoint x="480" y="178"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>